# Copie este arquivo para .env e preencha com seus dados

# Banco de dados (PostgreSQL no Railway)
DATABASE_URL=postgresql://usuario:senha@host:5432/carteira

# JWT Secret — coloque qualquer texto longo e aleatório
JWT_SECRET=sua_chave_secreta_muito_longa_aqui_123456

# Porta do servidor
PORT=3001

# URL do frontend (para o CORS)
FRONTEND_URL=https://seu_usuario.github.io
